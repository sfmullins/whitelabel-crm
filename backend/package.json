{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "files": [
    "dist",
    "drizzle"
  ],
  "main": "./dist/embed.js",
  "types": "./dist/embed.d.ts",
  "exports": {
    ".": {
      "types": "./dist/embed.d.ts",
      "require": "./dist/embed.js",
      "default": "./dist/embed.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:seed": "tsx src/infrastructure/database/seed.ts"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "pdfkit": "^0.15.0",
    "shared": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/pdfkit": "^0.13.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "^3.2.7"
  }
}
